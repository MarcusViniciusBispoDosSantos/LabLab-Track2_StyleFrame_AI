# Track 2 does NOT receive a harness API key.
# Default is auto: API if VISION_API_KEY is available, local_blip if installed, otherwise heuristic fallback.
CAPTION_BACKEND=auto

# Optional OpenAI-compatible vision API mode
# VISION_API_KEY=
# VISION_BASE_URL=https://api.openai.com/v1
# VISION_MODEL=gpt-4o-mini

# Optional local BLIP mode
# CAPTION_BACKEND=local_blip
# LOCAL_MODEL_ID=Salesforce/blip-image-captioning-base

# Sampling and runtime knobs
FRAME_SAMPLE_COUNT=6
DOWNLOAD_TIMEOUT_SECONDS=60
MAX_VIDEO_MB=250
INPUT_PATH=/input/tasks.json
OUTPUT_PATH=/output/results.json
